# ─────────────────────────────────────────────────────────────
#  BlizWare API — environment template
#  Copy to `.env` for local dev, or set these as real env vars on
#  your host for production. See DEPLOYMENT.md for the full guide.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────
PORT=5002
# Use "production" when you deploy (enables secure cookies, disables demo payments).
NODE_ENV=development
# Comma-separated allowed origins (your storefront domain in production).
CLIENT_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────
# Local: mongodb://127.0.0.1:27017/bliszware
# Production: your MongoDB Atlas SRV connection string.
MONGO_URI=mongodb://127.0.0.1:27017/bliszware

# ── Auth ──────────────────────────────────────────────────
# REQUIRED: generate a long random secret, e.g. `openssl rand -base64 48`
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=30d

# ── Google sign-in (optional) ─────────────────────────────
# OAuth 2.0 Client ID (Web application) from Google Cloud Console.
# Add your production domain to Authorised JavaScript origins.
# Leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=

# ── Cloudinary (image hosting, optional) ──────────────────
# Without these, the admin product editor falls back to image URLs.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── PayHere (Sri Lanka payment gateway) ───────────────────
# Sandbox: https://sandbox.payhere.lk  | Live: https://www.payhere.lk
PAYHERE_MODE=sandbox
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
# Must be a PUBLIC https URL in production (PayHere posts the payment result here).
PAYHERE_NOTIFY_URL=https://your-api-domain.com/api/payments/payhere/notify

# ── Demo payments ─────────────────────────────────────────
# The /api/payments/confirm endpoint marks Genie/iPay orders paid WITHOUT a
# verified gateway callback. It is disabled in production unless you set this
# to "true". Only enable if you know what you're doing.
ALLOW_DEMO_PAYMENTS=false

# ── Couriers (Sri Lanka, optional) ────────────────────────
# Leave blank to use demo tracking numbers. Add a key to go live with a courier.
KOOMBIYO_API_KEY=
DOMEX_API_KEY=
PRONTO_API_KEY=

# ── Email (order confirmations & alerts) ──────────────────
# FREE option: Gmail SMTP. Turn on 2-Step Verification, then create an
# "App password" (Google Account → Security → App passwords) and use it as
# SMTP_PASS. Other free options: Brevo (smtp-relay.brevo.com) or Mailtrap.
# Until SMTP_PASS is filled, emails are logged to the console instead of sent.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=
EMAIL_FROM="Bliszware <your-gmail@gmail.com>"

# ── Super admin account ───────────────────────────────────
# Used by `npm run seed` and `npm run superadmin`.
# CHANGE THE PASSWORD before seeding a production database.
SUPERADMIN_NAME=Bliszware Admin
SUPERADMIN_EMAIL=Bliszwear@gmail.com
SUPERADMIN_PASSWORD=change_this_password

# ── Owner alert recipient ─────────────────────────────────
# Where new-order and low-stock alert emails are sent (optional).
ADMIN_EMAIL=owner@bliszware.lk
